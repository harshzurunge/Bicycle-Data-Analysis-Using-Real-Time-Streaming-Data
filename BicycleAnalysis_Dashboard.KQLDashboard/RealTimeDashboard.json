  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\nLatestStationSnapshot\n| count",
      "id": "b7b8d45c-316e-4142-997f-5f194c9c1bd5",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| summarize Total_Bikes = sum(No_Bikes)",
      "id": "97a80a58-c8e8-483e-87fb-cb32356321b8",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| summarize Total_Empty_Docks = sum(No_Empty_Docks)",
      "id": "a63b5983-da8d-495e-ae1e-551be1d05de3",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| where No_Bikes == 0\n| count",
      "id": "70328f6a-a703-4b7f-b58c-93cb35b03f19",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| where No_Empty_Docks == 0\n| count",
      "id": "2ed75ee8-bab6-4990-a16b-fe48fa8a95dd",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| where No_Bikes < 5\n| count",
      "id": "b6137942-5afb-4a66-a046-38f5744f6010",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | where current_time > ago(10m)   // avoid stale stations\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| extend \n    Total_Capacity = No_Bikes + No_Empty_Docks,\n    Availability_Status = case(\n        No_Bikes == 0, \"Empty\",\n        No_Bikes <= 10, \"Low\",\n        \"Healthy\"\n    )\n| project \n    BikepointID,\n    Street,\n    Neighbourhood,\n    Latitude,\n    Longitude,\n    No_Bikes,\n    No_Empty_Docks,\n    Total_Capacity,\n    Availability_Status",
      "id": "8c8f9ef9-d70a-44d8-9a5e-5d9a24b3a20f",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | where current_time > ago(10m)\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| extend \n    Status = case(\n        No_Bikes == 0, \"Empty Station\",\n        No_Empty_Docks == 0, \"Full Station\",\n        No_Bikes <= 5, \"Low Bikes\",\n        \"Healthy\"\n    ),\n    Severity = case(\n        No_Bikes == 0, 1,\n        No_Empty_Docks == 0, 2,\n        No_Bikes <= 5, 3,\n        4\n    )\n| where Status != \"Healthy\"\n| sort by Severity asc, No_Bikes asc\n| project \n    BikepointID,\n    Neighbourhood,\n    No_Bikes,\n    No_Empty_Docks,\n    Status",
      "id": "0c10d968-aa78-4e16-bab0-541570c17a7f",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | where current_time > ago(10m)\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| summarize Total_Bikes = sum(No_Bikes) by Neighbourhood\n| sort by Total_Bikes desc",
      "id": "05531a96-e642-4fb2-a1e0-c1acc7942941",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "let LatestStationSnapshot =\n    Bike_Data\n    | where current_time > ago(10m)\n    | summarize arg_max(current_time, *) by BikepointID;\n\nLatestStationSnapshot\n| extend Utilization = \n    (No_Bikes * 100.0) / (No_Bikes + No_Empty_Docks)\n| summarize Avg_Utilization = round(avg(Utilization),2) \n    by Neighbourhood\n| sort by Avg_Utilization desc",
      "id": "9433e2e1-b67e-4b39-8af3-91fba6782855",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e6cc3b67-b278-42b7-b790-ad77159575cd"
      },
      "text": "Bike_Data\n| where current_time > ago(60m)\n| summarize Total_Bikes = sum(No_Bikes) \n    by bin(current_time, 5m)\n| sort by current_time asc",
      "id": "ceab7ee0-764a-492d-b3a9-7985a45a2928",
      "usedVariables": []
    }
  ]
}